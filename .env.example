# =============================================================
# StreamWeaver Pro — Variables de entorno (ejemplo)
# Copia este archivo a `.env` y ajusta los valores.
# Variables expuestas al frontend DEBEN empezar por VITE_
# =============================================================

# --- App ---
VITE_APP_NAME="StreamWeaver Pro"
VITE_APP_ENV="development"          # development | staging | production

# --- Modo de autenticación ---
# mock = usa usuarios de demo en localStorage (sin backend)
# api  = usa el backend real definido en VITE_API_BASE_URL
VITE_AUTH_MODE="mock"

# --- API backend (cuando exista) ---
VITE_API_BASE_URL="http://localhost:8080/api"
VITE_API_TIMEOUT="15000"

# =============================================================
# Backend (NO se expone al frontend — sin prefijo VITE_)
# =============================================================

# --- Base de datos (PostgreSQL + Prisma) ---
DATABASE_URL="postgresql://user:password@localhost:5432/streamweaver"

# --- Autenticación real ---
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"
BCRYPT_ROUNDS="12"

# --- Servidores de streaming (futuro) ---
# STREAM_NODES="node-1:10.0.0.11,node-2:10.0.0.12"
# FFMPEG_PATH="/usr/bin/ffmpeg"

# --- Almacenamiento VOD (futuro) ---
# S3_ENDPOINT=""
# S3_BUCKET=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""

# --- Seguridad ---
RATE_LIMIT_PER_MINUTE="60"
ENABLE_2FA="false"

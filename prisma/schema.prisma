// StreamWeaver Pro — Esquema de base de datos
// ORM: Prisma · Motor: PostgreSQL
//
// Jerarquía real de revendedores:
//   admin → superreseller → reseller → subreseller → customer (cliente final)
//
// - `User` con parentId + credits: cuentas del panel encadenadas en árbol.
// - `Customer` con resellerId: cliente final "consume" 1 crédito al crearse.
// - `CreditTransaction`: log auditable de todos los movimientos de créditos.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  support
  superreseller
  reseller
  subreseller
}

enum UserStatus {
  active
  suspended
}

enum CustomerStatus {
  active
  expired
  suspended
}

enum CreditTxKind {
  admin_topup       // Admin inyecta créditos (sin descontar de nadie).
  transfer_in       // Padre → hijo (hijo recibe).
  transfer_out      // Hijo → padre (padre recupera).
  customer_create   // Consumo por crear customer.
  customer_refund   // Devolución al eliminar customer (opcional / admin).
  adjust            // Ajuste manual del admin.
}

model User {
  id            String     @id @default(uuid())
  name          String
  email         String     @unique
  username      String     @unique
  passwordHash  String     @map("password_hash")
  role          UserRole   @default(support)
  status        UserStatus @default(active)
  credits       Int        @default(0)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt      @map("updated_at")
  lastLogin     DateTime?  @map("last_login")

  // Jerarquía de revendedores (self-relation).
  parentId      String?    @map("parent_id")
  parent        User?      @relation("UserTree", fields: [parentId], references: [id], onDelete: SetNull)
  children      User[]     @relation("UserTree")

  // Clientes finales creados por este usuario (owner directo).
  customers     Customer[] @relation("ResellerCustomers")

  // Movimientos de créditos.
  txAsActor     CreditTransaction[] @relation("CreditActor")
  txAsFrom      CreditTransaction[] @relation("CreditFrom")
  txAsTo        CreditTransaction[] @relation("CreditTo")

  @@index([role])
  @@index([status])
  @@index([parentId])
  @@map("users")
}

model Customer {
  id              String         @id @default(uuid())
  client          String?
  username        String         @unique
  passwordHash    String?        @map("password_hash")
  package         String         @default("Básico")
  status          CustomerStatus @default(active)
  expiresAt       DateTime?      @map("expires_at")
  maxConnections  Int            @default(1)        @map("max_connections")
  notes           String?

  // Dueño directo (super/reseller/subreseller). Admin puede reasignar.
  resellerId      String?        @map("reseller_id")
  reseller        User?          @relation("ResellerCustomers", fields: [resellerId], references: [id], onDelete: SetNull)

  deletedAt       DateTime?      @map("deleted_at")   // Soft delete.
  createdAt       DateTime       @default(now())     @map("created_at")
  updatedAt       DateTime       @updatedAt          @map("updated_at")

  transactions    CreditTransaction[]

  @@index([status])
  @@index([resellerId])
  @@index([deletedAt])
  @@map("customers")
}

model CreditTransaction {
  id           String        @id @default(uuid())
  actorId      String        @map("actor_id")
  actor        User          @relation("CreditActor", fields: [actorId], references: [id], onDelete: Cascade)

  fromUserId   String?       @map("from_user_id")
  fromUser     User?         @relation("CreditFrom", fields: [fromUserId], references: [id], onDelete: SetNull)

  toUserId     String?       @map("to_user_id")
  toUser       User?         @relation("CreditTo", fields: [toUserId], references: [id], onDelete: SetNull)

  customerId   String?       @map("customer_id")
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)

  delta        Int           // magnitud (positiva) transferida/consumida
  kind         CreditTxKind
  reason       String?

  createdAt    DateTime      @default(now()) @map("created_at")

  @@index([actorId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([customerId])
  @@index([createdAt])
  @@map("credit_transactions")
}
